# ============================================================
# THE AI BOARDROOM — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Supabase (swap these when migrating to US region) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# --- AI Models ---
GEMINIFLASH_API_KEY=your-gemini-key
# ANTHROPIC_API_KEY=          # Optional
# OPENAI_API_KEY=             # Optional

# --- Google Cloud (Vertex AI + RAG) ---
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# VERTEX_PROJECT=your-project  # Phase 2: for US region models
# VERTEX_LOCATION=us-central1  # Phase 2: for US region models

# --- Search ---
SERPAPI_API_KEY=your-serpapi-key

# --- Phase 2 (uncomment when ready) ---
# GOOGLE_DRIVE_CREDENTIALS=path/to/drive-service-account.json
# WHATSAPP_API_TOKEN=your-twilio-or-wppconnect-token
# WHATSAPP_PHONE_ID=your-phone-id
